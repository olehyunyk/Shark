# Neon — локально можна DATABASE_URL або окремі Shark_* (як на Vercel)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Shark_POSTGRES_URL=
# Shark_POSTGRES_USER=
# Shark_POSTGRES_PASSWORD=
# Shark_POSTGRES_HOST=
# Shark_POSTGRES_DATABASE=
# NEON_ENV_PREFIX=Shark

# Jira Cloud
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=

# JQL за замовчуванням (опційно)
# JIRA_JQL=assignee = currentUser() AND resolution = Unresolved ORDER BY duedate ASC

# Секрет для ручної синхронізації та Vercel Cron (згенеруйте довгий random string)
CRON_SECRET=
