# Neon Postgres (Vercel integration підставить DATABASE_URL автоматично)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Jira Cloud
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=

# JQL за замовчуванням (опційно)
# JIRA_JQL=assignee = currentUser() AND resolution = Unresolved ORDER BY duedate ASC

# Секрет для ручної синхронізації та Vercel Cron (згенеруйте довгий random string)
CRON_SECRET=
