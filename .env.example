# Neon — locally use DATABASE_URL or Shark_* (same as Vercel)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Shark_POSTGRES_URL=
# Shark_POSTGRES_USER=
# Shark_POSTGRES_PASSWORD=
# Shark_POSTGRES_HOST=
# Shark_POSTGRES_DATABASE=
# NEON_ENV_PREFIX=Shark

# Jira Cloud — SharksCode MK board
JIRA_BASE_URL=https://sharkscode.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=

# Default JQL (optional; code default is project MK)
# JIRA_JQL=project = MK AND resolution = Unresolved ORDER BY duedate ASC

# Secret for manual sync, migrate, and Vercel Cron (long random string)
CRON_SECRET=
